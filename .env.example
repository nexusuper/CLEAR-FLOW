# Database
TURSO_DATABASE_URL=libsql://your-db-name-your-username.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
POSTGRES_URL=postgresql://user:password@host/database

# Admin
ADMIN_PASSWORD=change-this-password

# Facebook Integration
# Get these from Facebook Developer Portal: https://developers.facebook.com

# Meta Pixel ID (for tracking conversions)
# Found in Events Manager > Data Sources > Your Pixel
NEXT_PUBLIC_FB_PIXEL_ID=your-pixel-id

# Facebook Page ID (for Messenger Chat Plugin)
# Found in Page Settings > Page Info > Page ID
NEXT_PUBLIC_FB_PAGE_ID=your-page-id

# Page Access Token (for Messenger API - sending notifications)
# Generate in Facebook Developer Portal > Your App > Messenger > Settings
FB_PAGE_ACCESS_TOKEN=your-page-access-token

# Webhook Verify Token (any secret string you choose)
# Use this when setting up Messenger webhook in Facebook Developer Portal
FB_VERIFY_TOKEN=your-webhook-verify-token

# Facebook App Secret (for verifying webhook signatures)
# Found in Facebook Developer Portal > Your App > Settings > Basic
FB_APP_SECRET=your-app-secret

# Webhook Secret for ManyChat/FB order intake (REQUIRED — endpoint rejects without it)
FB_WEBHOOK_SECRET=your-manychat-webhook-secret
